@page "/pages/contacts/edit/{id:int}"
@using CleanArchitecture.Blazor.Application.Features.Contacts.Commands.Update
@using CleanArchitecture.Blazor.Application.Features.Contacts.Queries.GetById
@using CleanArchitecture.Blazor.Server.UI.Components.Presence

@inherits MudComponentBase
@inject IValidationService Validator
@inject IStringLocalizer<Contacts> L
@attribute [Authorize(Policy = Permissions.Contacts.Edit)]

<PageTitle>@Title</PageTitle>
<Breadcrumbs OnSaveButtonClick="OnSubmit" Saving="_saving" BreadcrumbItems="_breadcrumbItems"></Breadcrumbs>

@if (_command != null)
{
    <MudCard Class="pa-2">
        <MudCardHeader>
            <CardHeaderContent>
                 <MudText Typo="Typo.h6">@L["Edit Contact"]</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
        <ActiveUserSession PageComponent="@($"{nameof(EditContact)}/{ _command.Id }")" />
        <MudForm Model="@_command" @ref="@_contactForm" Validation="@(Validator.ValidateValue(_command))">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="6"> 
                        <MudTextField Label="@L[_command.GetMemberDisplayName(x=>x.Name)]" @bind-Value="_command.Name" For="@(() => _command.Name)" Required="true" RequiredError="@L["name is required."]" Placeholder="@L["Enter name"]"></MudTextField>
                </MudItem> 
<MudItem xs="12" md="6"> 
                        <MudTextField Label="@L[_command.GetMemberDisplayName(x=>x.Description)]"  For="@(() => _command.Description)" @bind-Value="_command.Description" Placeholder="@L["Enter description number"]"></MudTextField>
                </MudItem> 
<MudItem xs="12" md="6"> 
                        <MudTextField Label="@L[_command.GetMemberDisplayName(x=>x.Email)]" @bind-Value="_command.Email" For="@(() => _command.Email)" Required="false" RequiredError="@L["email is required."]" Placeholder="@L["Enter email"]"></MudTextField>
                </MudItem> 
<MudItem xs="12" md="6"> 
                        <MudTextField Label="@L[_command.GetMemberDisplayName(x=>x.PhoneNumber)]" @bind-Value="_command.PhoneNumber" For="@(() => _command.PhoneNumber)" Required="false" RequiredError="@L["phone number is required."]" Placeholder="@L["Enter phone number"]"></MudTextField>
                </MudItem> 
<MudItem xs="12" md="6"> 
                        <MudTextField Label="@L[_command.GetMemberDisplayName(x=>x.Country)]" @bind-Value="_command.Country" For="@(() => _command.Country)" Required="false" RequiredError="@L["country is required."]" Placeholder="@L["Enter country"]"></MudTextField>
                </MudItem> 

            </MudGrid>
        </MudForm>
        </MudCardContent>
        <MudCardActions Class="d-flex justify-end gap-2">
                    <MudLoadingButton Color="Color.Primary" Variant="Variant.Outlined" Loading="@_saving" OnClick="OnSubmit">@AppStrings.Save</MudLoadingButton>
        </MudCardActions>
        </MudCard>
    }

 

@code {
    public string Title { get; private set; }= string.Empty;
    [Parameter]
    public int Id { get; set; }
    MudForm _contactForm = new();
    private bool _saving = false;
    private List<BreadcrumbItem>? _breadcrumbItems = [];
    private UpdateContactCommand? _command;
    protected override async Task OnInitializedAsync()
    {
        Title =  $"{ApplicationSettings.AppName} - { L["Edit Contact"] }";
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(L["Home"], href: "/"),
            new BreadcrumbItem(L["Contacts"], href: "/pages/contacts")
        };
        var result = await Mediator.Send(new GetContactByIdQuery() { Id = Id });
        result.Map(data =>
        {
            _command = ObjectMapper.Map<UpdateContactCommand>(data);
            return data;
        }).Match(data =>
        {
            _breadcrumbItems.Add(new BreadcrumbItem(data.Name, href: $"/pages/contacts/edit/{Id}"));
        }, errors =>
        {
            Snackbar.Add($"{errors}", Severity.Error);
        });

    }
    async Task OnSubmit()
    {
        try
        {
            _saving = true;
            await _contactForm.ValidateAsync();
            if (!_contactForm.IsValid)
                return;
            var result = await Mediator.Send(_command!);
            result.Match(
                data=>
                {
                    Snackbar.Add(AppStrings.SaveSuccess, MudBlazor.Severity.Info);
                },
                errors=>
                {
                    Snackbar.Add(string.Join(", ", errors), MudBlazor.Severity.Error);
                });
        }
        finally
        {
            _saving = false;
        }
    }
}
