@page "/pages/contacts"

@using CleanArchitecture.Blazor.Application.Features.Contacts.Caching
@using CleanArchitecture.Blazor.Application.Features.Contacts.DTOs
@using CleanArchitecture.Blazor.Application.Features.Contacts.Specifications
@using CleanArchitecture.Blazor.Application.Features.Contacts.Commands.Delete
@using CleanArchitecture.Blazor.Application.Features.Contacts.Commands.Import
@using CleanArchitecture.Blazor.Application.Features.Contacts.Queries.Export
@using CleanArchitecture.Blazor.Application.Features.Contacts.Queries.Pagination
@using CleanArchitecture.Blazor.Application.Features.Contacts.Commands.AddEdit
@using CleanArchitecture.Blazor.Server.UI.Pages.Contacts.Components

@inject IStringLocalizer<Contacts> L
@inject BlazorDownloadFileService BlazorDownloadFileService

@attribute [Authorize(Policy = Permissions.Contacts.View)]
<PageTitle>@Title</PageTitle>

<MudDataGrid ServerData="@(ServerReload)"
                  FixedHeader="true"
                  FixedFooter="false"
                  Virtualize="false"
                  @bind-RowsPerPage="_defaultPageSize"
                  Loading="@_loading"
                  MultiSelection="true"
                  T="ContactDto"
                  SelectOnRowClick="false"
                  RowClick="@(s=>OnDataGridRowClick(s.Item))"
                  @bind-SelectedItems="_selectedContacts"
                  Hover="true" @ref="_contactsGrid">
            <ToolBarContent>
                 <MudStack Row Spacing="0" Class="flex-grow-1" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Start">
                <MudIcon Icon="@Icons.Material.Filled.Window" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">@L[_contactDto.GetClassDescription()]</MudText>
                    <MudEnumSelect Style="min-width:120px" TEnum="ContactListView" ValueChanged="OnListViewChanged" Value="_contactsQuery.ListView" Dense="true" Label="@AppStrings.ListView">
                    </MudEnumSelect>
                </MudStack>
            </MudStack>
            <MudStack Spacing="2" AlignItems="AlignItems.End">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                    <MudButton Disabled="@_loading"
                               OnClick="@(() => OnRefresh())"
                               StartIcon="@Icons.Material.Outlined.Refresh">
                        @AppStrings.Refresh
                    </MudButton>
                    @if (_accessRights.Create)
                    {
                        <MudButton StartIcon="@Icons.Material.Outlined.Add"
                                   OnClick="OnCreate">
                            @AppStrings.New
                        </MudButton>
                    }
                    @if (_accessRights.Delete)
                    {
                            <MudButton Disabled="@(!(_selectedContacts.Count > 0))"
                                       StartIcon="@Icons.Material.Outlined.DeleteOutline"
                                         OnClick="OnDeleteSelectedContacts">
                                @AppStrings.Delete
                            </MudButton>
                    }
                    <MudMenu TransformOrigin="Origin.BottomRight" AnchorOrigin="Origin.BottomRight" EndIcon="@Icons.Material.Filled.MoreVert" Label="@AppStrings.More">
                        @if (_accessRights.Clone)
                        {
                            <MudMenuItem Disabled="@(_selectedContacts.Count != 1)" OnClick="OnCloneContact">@AppStrings.Clone</MudMenuItem>
                        }
                        
                        @if (_accessRights.Export)
                        {
                            <MudMenuItem Disabled="@_exporting"
                                         OnClick="OnExport">
                                @AppStrings.Export
                            </MudMenuItem>
                        }
                        @if (_accessRights.Import)
                        {
                            <MudMenuItem>
                                <MudFileUpload T="IBrowserFile" FilesChanged="OnImportData" Accept=".xlsx">
                                    <CustomContent>
                                        <MudButton Class="pa-0 ma-0" Style="font-weight:400;text-transform:none;"
                                                   OnClick="@context.OpenFilePickerAsync"
                                                   Variant="Variant.Text"
                                                   Disabled="@_uploading">
                                            @AppStrings.Import
                                        </MudButton>
                                    </CustomContent>
                                    <SelectedTemplate></SelectedTemplate>
                                </MudFileUpload>
                            </MudMenuItem>
                        }
                    </MudMenu>
                </MudStack>
                <MudStack Row Spacing="1">
                    @if (_accessRights.Search)
                    {
                        <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Value="@_contactsQuery.Keyword" Placeholder="@AppStrings.Search" Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small">
                        </MudTextField>
                    }
                </MudStack>
            </MudStack>
        </MudStack>
            </ToolBarContent>
            <Columns>
                <SelectColumn ShowInFooter="false"></SelectColumn>
                <TemplateColumn HeaderStyle="width:60px" Title="@AppStrings.Actions" Sortable="false">
                    <CellTemplate>
                        @if (_accessRights.Edit || _accessRights.Delete)
                        {
                            <MudMenu Icon="@Icons.Material.Filled.Edit" Variant="Variant.Outlined" Size="Size.Small"
                                     Dense="true"
                                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown" IconColor="Color.Info" AnchorOrigin="Origin.CenterLeft">
                                @if (_accessRights.Edit)
                                {
                                    <MudMenuItem OnClick="@(()=>OnEditContact(context.Item))">@AppStrings.Edit</MudMenuItem>
                                }
                                @if (_accessRights.Delete)
                                {
                                    <MudMenuItem OnClick="@(()=>OnDeleteContact(context.Item))">@AppStrings.Delete</MudMenuItem>
                                }
                            </MudMenu>
                        }
                        else
                        {
                            <MudTooltip Text="@AppStrings.NoAllowed" Delay="300">
                                <MudIconButton Variant="Variant.Outlined"  
                                               Disabled="true"
                                               Icon="@Icons.Material.Filled.DoNotTouch"
                                               Size="Size.Small"
                                               Color="Color.Surface">
                                    @AppStrings.NoAllowed
                                </MudIconButton>
                            </MudTooltip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Name" Title="@L[_contactDto.GetMemberDisplayName(x=>x.Name)]"> 
   <CellTemplate>
      <div class="d-flex flex-column">
        <MudText Typo="Typo.body1">@context.Item.Name</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@context.Item.Description</MudText>
     </div>
    </CellTemplate>
</PropertyColumn>
                <PropertyColumn Property="x => x.Email" Title="@L[_contactDto.GetMemberDisplayName(x=>x.Email)]" />
                <PropertyColumn Property="x => x.PhoneNumber" Title="@L[_contactDto.GetMemberDisplayName(x=>x.PhoneNumber)]" />
                <PropertyColumn Property="x => x.Country" Title="@L[_contactDto.GetMemberDisplayName(x=>x.Country)]" />

            </Columns>
            <NoRecordsContent>
	            <MudDataGridStatus  Text="@AppStrings.NoRecords" Icon="@Icons.Material.TwoTone.FolderOff" />
	        </NoRecordsContent>
	        <LoadingContent>
		        <MudDataGridStatus  IsLoading="true" Text="@AppStrings.Loading" />
	        </LoadingContent>
            <PagerContent>
                <MudDataGridPager PageSizeOptions="@(new int[]{10,15,30,50,100,500,1000})" />
            </PagerContent>
</MudDataGrid>



@code {
    public string Title { get; private set; } = string.Empty;
    private int _defaultPageSize = 15;
    private HashSet<ContactDto> _selectedContacts = new HashSet<ContactDto>();
    private MudDataGrid<ContactDto> _contactsGrid = default!;
    private ContactDto _contactDto = new();
    private bool _loading;
    private bool _uploading;
    private bool _exporting;
    private UserProfile UserProfile => UserProfileState.Value;


    private ContactsWithPaginationQuery _contactsQuery { get; set; } = new();
    private ContactsAccessRights _accessRights = new();

    protected override async Task OnInitializedAsync()
    {
        Title = $"{ApplicationSettings.AppName} - { L[_contactDto.GetClassDescription()] }";
        _accessRights = await PermissionService.GetAccessRightsAsync<ContactsAccessRights>(); 
    }
     
    private async Task<GridData<ContactDto>> ServerReload(GridState<ContactDto> state, CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            _contactsQuery.CurrentUser = UserProfile;
            var sortDefinition = state.SortDefinitions.FirstOrDefault();
            _contactsQuery.OrderBy = sortDefinition?.SortBy ?? "Id";
            _contactsQuery.SortDirection = sortDefinition == null
									  ? SortDirection.Descending.ToString()
									  : (sortDefinition.Descending ? SortDirection.Descending.ToString() : SortDirection.Ascending.ToString());
            _contactsQuery.PageNumber = state.Page + 1;
            _contactsQuery.PageSize = state.PageSize;
            var result = await Mediator.Send(_contactsQuery, cancellationToken).ConfigureAwait(false);
            return new GridData<ContactDto>() { TotalItems = result.TotalItems, Items = result.Items };
        }
        finally
        {
            _loading = false;
        }

    }
    private async Task OnSearch(string text)
    {
        _selectedContacts = new();
        _contactsQuery.Keyword = text;
        await _contactsGrid.ReloadServerData();
    }
    private async Task OnListViewChanged(ContactListView listview)
    {
        _contactsQuery.ListView = listview;
        await _contactsGrid.ReloadServerData();
    }
    private async Task OnRefresh()
    {
        await AppCache.RemoveByTagsAsync(ContactCacheKey.Tags);
        _selectedContacts = new();
        _contactsQuery.Keyword  = string.Empty;
        await _contactsGrid.ReloadServerData();
    }
    private Task ShowEditFormDialog(string title, AddEditContactCommand command)
    {
        return DialogServiceHelper.ShowFormDialogAsync<ContactFormDialog, AddEditContactCommand>(
            title,
            async (res) =>
            {
                await _contactsGrid.ReloadServerData();
                _selectedContacts = new();
            },
            para =>
			{
				para.Add(x => x._command, command);
			}
            );
    }
    private void OnDataGridRowClick(ContactDto dto)
    {
        Navigation.NavigateTo($"/pages/contacts/view/{dto.Id}");
    }
    private Task OnCreate()
    {
        var command = new AddEditContactCommand();
        return ShowEditFormDialog(L["New Contact"], command);
    }
    private Task OnCloneContact()
    {
        var dto = _selectedContacts.First();
        var command = new AddEditContactCommand()
        {
                    Name = dto.Name, 
        Description = dto.Description, 
        Email = dto.Email, 
        PhoneNumber = dto.PhoneNumber, 
        Country = dto.Country, 

        };
        return ShowEditFormDialog(L["Clone Contact"], command);
    }
    private Task OnEditContact(ContactDto dto)
    {
       //var command = ObjectMapper.Map<AddEditContactCommand>(dto);
       //return ShowEditFormDialog(L["Edit Contact"], command);
       Navigation.NavigateTo($"/pages/contacts/edit/{dto.Id}");
       return Task.CompletedTask;
    }

    private Task OnDeleteContact(ContactDto dto)
    {
        var contentText = string.Format(AppStrings.DeleteConfirmation, dto.Name);
        var command = new DeleteContactCommand(new int[] { dto.Id });
        return DeleteContactsInternal(command, contentText); 
    }

    private Task OnDeleteSelectedContacts()
    {
        var contentText = string.Format(AppStrings.DeleteConfirmWithSelected, _selectedContacts.Count);
        var command = new DeleteContactCommand(_selectedContacts.Select(x => x.Id).ToArray());
        return DeleteContactsInternal(command, contentText);
    }

    private Task DeleteContactsInternal(DeleteContactCommand command, string contentText)
    {
        return DialogServiceHelper.ShowDeleteConfirmationDialogAsync(
            command,
            AppStrings.DeleteConfirmationTitle,
            contentText,
            async () =>
            {
                await _contactsGrid.ReloadServerData();
                _selectedContacts = new();
            });
    }


    private async Task OnExport()
    {
        _exporting = true;
        try
		{
            var request = new ExportContactsQuery()
                {
                    Keyword = _contactsQuery.Keyword,
                    CurrentUser = UserProfile,
                    ListView = _contactsQuery.ListView,
                    OrderBy = _contactsGrid.SortDefinitions.Values.FirstOrDefault()?.SortBy ?? "Id",
                    SortDirection = (_contactsGrid.SortDefinitions.Values.FirstOrDefault()?.Descending ?? true) ? SortDirection.Descending.ToString() : SortDirection.Ascending.ToString()
                };
            var result = await Mediator.Send(request);
            await result.MatchAsync(
            async data =>
            {
                await BlazorDownloadFileService.DownloadFileAsync($"{L["Contacts"]}.xlsx", data, contentType:"application/octet-stream");
                Snackbar.Add($"{AppStrings.ExportSuccess}", MudBlazor.Severity.Info);
            },
            errors =>
            {
                Snackbar.Add($"{errors}", MudBlazor.Severity.Error);
                return Task.CompletedTask;
            });
        }
		catch (Exception ex)
		{
			Snackbar.Add($"Export failed: {ex.Message}", MudBlazor.Severity.Error);
		}
		finally
		{
			_exporting = false;
		}
    }
    private async Task OnImportData(IBrowserFile file)
    {
        _uploading = true;
        try
		{
           using var fileStream = file.OpenReadStream();
		   using var stream = new MemoryStream();
		   await fileStream.CopyToAsync(stream);
           var command = new ImportContactsCommand(file.Name, stream.ToArray());
           var result = await Mediator.Send(command);
           await result.MatchAsync(
               async data =>
               {
                   await _contactsGrid.ReloadServerData();
                   Snackbar.Add($"{AppStrings.ImportSuccess}", MudBlazor.Severity.Info);
               }, errors =>
               {
                   Snackbar.Add($"{errors}", MudBlazor.Severity.Error);
                   return Task.CompletedTask;
               });
        }
		catch (Exception ex)
		{
			Snackbar.Add($"Import failed: {ex.Message}", MudBlazor.Severity.Error);
		}
		finally
		{
			_uploading = false;
		}
    }

}
