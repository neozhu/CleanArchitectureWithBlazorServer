@using CleanArchitecture.Blazor.Server.UI.Pages.Identity.Forgot
@using System.ComponentModel.DataAnnotations
@using CleanArchitecture.Blazor.Server.UI.Resources.ValidationMessages
@inherits MudComponentBase
@inject IStringLocalizer<ResetPassword> L
<MudDialog>
    <DialogContent>
        <EditForm EditContext="@_formEditContext">
            <DataAnnotationsValidator />
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField Label="@L["User Name"]" For="@(() => Model.UserName)" Value="Model.UserName" Required="true" ReadOnly></MudTextField>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField InputType="@(_isNewPasswordVisible ? InputType.Text : InputType.Password)"
                                  Label="@L["New Password"]"
                                  @bind-Value="Model.Password"
                                  For="@(() => Model.Password)"
                                  Variant="Variant.Text"
                                  Required="true"
                                  Class="mt-4"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_isNewPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="@(() => _isNewPasswordVisible = !_isNewPasswordVisible)" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField InputType="@(_isConfirmPasswordVisible ? InputType.Text : InputType.Password)"
                                  Label="@L["Confirm New Password"]"
                                  @bind-Value="Model.ConfirmPassword"
                                  For="@(() => Model.ConfirmPassword)"
                                  Variant="Variant.Text"
                                  Required="true"
                                  Class="mt-4"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_isConfirmPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="@(() => _isConfirmPasswordVisible = !_isConfirmPasswordVisible)" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelDialog">@AppStrings.Cancel</MudButton>
        <MudButton ButtonType="ButtonType.Button" Color="Color.Primary" OnClick="SubmitAsync">@AppStrings.Ok</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance DialogInstance { get; set; } = default!;

    [EditorRequired]
    [Parameter]
    public ResetPasswordModel Model { get; set; } = default!;

    private EditContext _formEditContext = default!;
    private bool _isNewPasswordVisible;
    private bool _isConfirmPasswordVisible;

    protected override void OnParametersSet()
        => _formEditContext = new EditContext(Model);

    private Task SubmitAsync()
    {
        if (_formEditContext.Validate())
        {
            DialogInstance.Close(DialogResult.Ok(true));
        }

        return Task.CompletedTask;
    }

    private void CancelDialog()
    {
        DialogInstance.Cancel();
    }

    public class ResetPasswordModel
    {
        [Required]
        public string UserId { get; set; } = string.Empty;

        [Required]
        public string UserName { get; set; } = string.Empty;

        [Required(
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordRequired))]
        [StringLength(50, MinimumLength = 8,
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordLength))]
        [RegularExpression(
            @"^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$",
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordComplexity))]
        [DataType(DataType.Password)]
        [Display(Name = "Password")]
        public string Password { get; set; } = string.Empty;

        [Required(
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.ConfirmPasswordRequired))]
        [DataType(DataType.Password)]
        [Display(Name = "Confirm Password")]
        [Compare(nameof(Password),
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordMismatch))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
