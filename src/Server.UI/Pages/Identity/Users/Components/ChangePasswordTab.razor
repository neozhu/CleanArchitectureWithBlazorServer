@using System.ComponentModel.DataAnnotations
@using CleanArchitecture.Blazor.Server.UI.Resources.ValidationMessages

@inherits OwningComponentBase
@inject IStringLocalizer<CleanArchitecture.Blazor.Server.UI.Pages.Identity.Users.Profile> L

<EditForm Model="@_passwordModel" OnValidSubmit="HandleValidSubmitAsync" style="display: flex; align-items: center; flex-direction: column;">
    <DataAnnotationsValidator />
    <MudGrid Spacing="2" Justify="Justify.Center" Style="max-width:300px">
        <MudItem sm="12" xs="12">
            <MudTextField InputType="@(_isCurrentPasswordVisible? InputType.Text: InputType.Password)"
                          Label="@L["Current Password"]"
                          For="@(() => _passwordModel.CurrentPassword)"
                          @bind-Value="_passwordModel.CurrentPassword"
                          Placeholder="@L["Enter your current password"]"
                          Required="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_isCurrentPasswordVisible? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="@(() => _isCurrentPasswordVisible = !_isCurrentPasswordVisible)" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField InputType="@(_isNewPasswordVisible? InputType.Text: InputType.Password)"
                          Label="@L["New Password"]"
                          For="@(() => _passwordModel.NewPassword)"
                          @bind-Value="_passwordModel.NewPassword"
                          Placeholder="@L["Enter a new password"]"
                          Required="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_isNewPasswordVisible? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="@(() => _isNewPasswordVisible = !_isNewPasswordVisible)" />
        </MudItem>
        <MudItem xs="12">
            <MudTextField InputType="@(_isConfirmPasswordVisible? InputType.Text: InputType.Password)"
                          Label="@L["Confirm New Password"]"
                          For="@(() => _passwordModel.ConfirmPassword)"
                          @bind-Value="_passwordModel.ConfirmPassword"
                          Placeholder="@L["Confirm your new password"]"
                          Required="true"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_isConfirmPasswordVisible? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="@(() => _isConfirmPasswordVisible = !_isConfirmPasswordVisible)" />
        </MudItem>
        <MudItem sm="12" xs="12" Class="d-flex justify-end">
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">
                <MudText>@L["Change Password"]</MudText>
            </MudButton>
        </MudItem>
    </MudGrid>
</EditForm>

@code {
    private ChangePasswordModel _passwordModel { get; set; } = null!;
    private UserProfile UserProfile => UserProfileState.Value;
    
    private UserManager<ApplicationUser> _userManager { get; set; } = null!;

    private bool _isCurrentPasswordVisible;
    private bool _isNewPasswordVisible;
    private bool _isConfirmPasswordVisible;
    protected override Task OnInitializedAsync()
    {
        _userManager = ScopedServices.GetRequiredService<UserManager<ApplicationUser>>();
        _passwordModel = new ChangePasswordModel
        {
            UserId = UserProfile?.UserId ?? string.Empty,
            CurrentPassword = string.Empty,
            NewPassword = string.Empty,
            ConfirmPassword = string.Empty
        };
        return Task.CompletedTask;
    }
    

 
 

    private async Task HandleValidSubmitAsync(EditContext context)
    {
        var user = await _userManager.FindByIdAsync(_passwordModel.UserId);
        if (user == null)
        {
            Snackbar.Add($"User [{_passwordModel.UserId}] not found.", Severity.Error);
            return;
        }
        var result = await _userManager.ChangePasswordAsync(user, _passwordModel.CurrentPassword, _passwordModel.NewPassword);
        if (result.Succeeded)
        {
            Snackbar.Add(L["Password changed successfully"], Severity.Info);
            // Clear the form
            _passwordModel.CurrentPassword = string.Empty;
            _passwordModel.NewPassword = string.Empty;
            _passwordModel.ConfirmPassword = string.Empty;
            StateHasChanged();
        }
        else
        {
            Snackbar.Add(string.Join(",", result.Errors.Select(e => e.Description)), Severity.Error);
        }
               
    }

    public class ChangePasswordModel
    {
        [Required]
        public string UserId { get; set; } = string.Empty;

        [Required(
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordRequired))]
        [StringLength(30, MinimumLength = 6,
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordLength))]
        [Display(Name = "Password")]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required(
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordRequired))]
        [StringLength(50, MinimumLength = 8,
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordLength))]
        [RegularExpression(
            @"^(?=.*[A-Z])(?=.*[a-z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$",
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordComplexity))]
        [DataType(DataType.Password)]
        [Display(Name = "Password")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.ConfirmPasswordRequired))]
        [DataType(DataType.Password)]
        [Display(Name = "Confirm Password")]
        [Compare(nameof(NewPassword),
            ErrorMessageResourceType = typeof(ValidationMessages),
            ErrorMessageResourceName = nameof(ValidationMessages.PasswordMismatch))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
