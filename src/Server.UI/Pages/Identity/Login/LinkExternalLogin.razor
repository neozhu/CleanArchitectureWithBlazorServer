@page "/account/linkexternallogin"
@using System.Security.Claims
@using System.Text
@using CleanArchitecture.Blazor.Domain.Identity
@using CleanArchitecture.Blazor.Server.UI.Pages.Identity.Register
@using Microsoft.AspNetCore.WebUtilities
@using CleanArchitecture.Blazor.Application.Features.Identity.Notifications.UserActivation
@using CleanArchitecture.Blazor.Application.Features.Tenants.DTOs
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using CleanArchitecture.Blazor.Server.UI.Resources.ValidationMessages

@inject ILogger<LinkExternalLogin> Logger
@inject IStringLocalizer<LinkExternalLogin> L

<PageTitle>@ApplicationSettings.AppName - @L["External Login"]</PageTitle>
<MudStack Spacing="2">
	<MudText Typo="Typo.h4" GutterBottom="true">@L["External Login"]</MudText>
	<MudText Typo="Typo.h6" GutterBottom="true">@string.Format(L["Associate your {0} account"], Provider)</MudText>

	<MudText Typo="Typo.body1">@string.Format(L["Authentication with {0} has been completed successfully. Please provide the required information below to complete your account registration and access the system"], Provider)</MudText>

	<EditForm Model="_formModel" OnValidSubmit="HandleValidSubmitAsync" FormName="confirmation">
		<DataAnnotationsValidator />
		<StatusMessage Message="@_statusMessage" Error="true" />
		<MudStack Spacing="2">
			<TenantSelect @bind-Value="_formModel.Tenant"
									 Label="@L["Tenant"]"
									 Variant="Variant.Outlined"
									 HelperText="@L["Select your organization or tenant"]"
									 Placeholder="@L["Please select a tenant"]"
									 Required="true"
									 For="@(() => _formModel.Tenant)" />

			<MudTextField T="string"
						  @bind-Value="_formModel.Email"
						  Label="@L["Email"]"
						  Variant="Variant.Outlined"
						  Margin="Margin.Normal"
						  InputType="InputType.Email"
						  HelperText="@L["Enter your professional email address"]"
						  Required="true"
						  RequiredError="@L["Email address is required"]"
						  Validation="@(new EmailAddressAttribute() { ErrorMessage = L["Please enter a valid email address"] })"
						  Placeholder="@L["Enter your email address"]" />

			<TimeZoneAutocomplete @bind-Value="_formModel.TimeZoneId"
								  T="string"
								  Label="@L["Time Zone"]"
								  Variant="Variant.Outlined"
								  Placeholder="@L["Select a time zone"]"
								  Required="true"
								  For="@(() => _formModel.TimeZoneId)" />
			<LanguageAutocomplete @bind-Value="_formModel.LanguageCode"
								  T="string"
								  Label="@L["Language"]"
								  Variant="Variant.Outlined"
								  Placeholder="@L["Select a language"]"
								  Required="true"
								  For="@(() => _formModel.LanguageCode)" />
			<MudButton Variant="Variant.Filled"
					   Color="Color.Primary"
					   Size="Size.Large"
					   ButtonType="ButtonType.Submit"
					   FullWidth="true">
				@L["Complete Registration"]
			</MudButton>
		</MudStack>
	</EditForm>
</MudStack>

@code {
	public const string PageUrl = "/account/linkexternallogin";
	public const string LoginCallbackAction = "LoginCallback";

	private string? _statusMessage;
	private InputModel _formModel { get; set; } = new();
	[SupplyParameterFromQuery] public string? Provider { get; set; }
	[SupplyParameterFromQuery] public string? Email { get; set; }
	[SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
	[SupplyParameterFromQuery] public string? LoginCallback { get; set; }



	protected override void OnInitialized()
	{
		if (string.IsNullOrWhiteSpace(Provider))
		{
			_statusMessage = L["Provider is not set."];

		}
		_formModel.Email = Email ?? "";
	}



	private Task HandleValidSubmitAsync()
	{
		var url = Navigation.GetUriWithQueryParameters(
				Navigation.ToAbsoluteUri(IdentityComponentsEndpointRouteBuilderExtensions.PerformLinkExternalLogin).AbsoluteUri,
				new Dictionary<string, object?>
				{
					["action"] = Uri.EscapeDataString(LoginCallback ?? LoginCallbackAction),
					["tenantId"] = Uri.EscapeDataString(_formModel.TenantId ?? string.Empty),
					["email"] = Uri.EscapeDataString(_formModel.Email),
					["returnUrl"] = Uri.EscapeDataString(ReturnUrl ?? "/"),
					["timezoneId"] = Uri.EscapeDataString(_formModel.TimeZoneId),
					["languageCode"] = Uri.EscapeDataString(_formModel.LanguageCode)
				});
		Navigation.NavigateTo(url, forceLoad: true);
		return Task.CompletedTask;
	}



	private sealed class InputModel
	{
		[Required(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.EmailRequired))]
		[EmailAddress(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.EmailInvalid))]
		public string Email { get; set; } = "";

		[Required(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.TenantRequired))]
		public string? TenantId => Tenant?.Id;

		[Required(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.TimeZoneRequired))]
		[Display(Name = "Time Zone")]
		public string TimeZoneId { get; set; } = TimeZoneInfo.Local.Id;

		[Required(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.LanguageRequired))]
		[Display(Name = "Language")]
		public string LanguageCode { get; set; } = CultureInfo.CurrentCulture.Name;

		[Required(
			ErrorMessageResourceType = typeof(ValidationMessages),
			ErrorMessageResourceName = nameof(ValidationMessages.TenantRequired))]
		public TenantDto? Tenant { get; set; }
	}

}
