@using System.Globalization
@using System.Linq.Expressions

<MudTextField T="string"
              Label="@Label"
              Value="@_textValue"
              ValueChanged="OnTextChanged"
              For="@_stringFor"
              InputType="InputType.DateTimeLocal"
              Disabled="@Disabled"
              ReadOnly="@ReadOnly"
              Required="@Required"
              RequiredError="@RequiredError"
              Immediate="@Immediate"
              Variant="@Variant"
              Margin="@Margin"
              Class="@Class"
              Error="@Error"
              ErrorText="@ErrorText"
              HelperText="@HelperText"
              Placeholder="@Placeholder"
              Step="@Step" />

@code {
    [Parameter] public string? Label { get; set; }

    [Parameter] public DateTime? Value { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }


    [Parameter] public Expression<Func<DateTime?>>? For { get; set; }

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? RequiredError { get; set; }

    [Parameter] public bool Immediate { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Text;
    [Parameter] public Margin Margin { get; set; } = Margin.Dense;
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Error { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? Placeholder { get; set; }

    [Parameter] public int Step { get; set; } = 60;

    private string? _textValue;


    private Expression<Func<string?>>? _stringFor;

    protected override void OnInitialized()
    {
        _stringFor = () => _textValue;
    }

    protected override void OnParametersSet()
    {
        var formatted = Format(Value);
        if (_textValue != formatted)
            _textValue = formatted;
    }

    private async Task OnTextChanged(string? value)
    {
        _textValue = value;

        if (string.IsNullOrWhiteSpace(value))
        {
            await SetValueAsync(null);
            return;
        }

        if (TryParse(value, out var parsed))
        {
            parsed = DateTime.SpecifyKind(parsed, DateTimeKind.Unspecified);
            await SetValueAsync(parsed);
        }
    }

    private async Task SetValueAsync(DateTime? newValue)
    {
        if (Value != newValue)
        {
            Value = newValue;
            await ValueChanged.InvokeAsync(newValue);
        }
    }

    private string? Format(DateTime? value)
    {
        if (!value.HasValue)
            return null;

        return Step == 1
            ? value.Value.ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture)
            : value.Value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
    }

    private static bool TryParse(string value, out DateTime result)
    {
        var formats = new[]
        {
            "yyyy-MM-ddTHH:mm",
            "yyyy-MM-ddTHH:mm:ss"
        };

        return DateTime.TryParseExact(
            value,
            formats,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out result);
    }
}